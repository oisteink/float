# Console — UART (output visible on /dev/ttyUSB0)
# USB_SERIAL_JTAG available as secondary output
CONFIG_ESP_CONSOLE_UART_DEFAULT=y

# Partition table
CONFIG_PARTITION_TABLE_SINGLE_APP_LARGE=y

# Flash — octal SPI, 32MB
CONFIG_ESPTOOLPY_OCT_FLASH=y
CONFIG_ESPTOOLPY_FLASHSIZE_32MB=y
CONFIG_ESPTOOLPY_HEADER_FLASHSIZE_UPDATE=y

# PSRAM — octal SPI, 80MHz
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y

# MSP3520 display SPI (pins 3–9 on header)
# Pin 3:  CS
CONFIG_MSP3520_DISPLAY_CS_GPIO=3
# Pin 4:  RESET
CONFIG_MSP3520_DISPLAY_RST_GPIO=46
# Pin 5:  DC/RS
CONFIG_MSP3520_DISPLAY_DC_GPIO=9
# Pin 6:  SDI (MOSI)
CONFIG_MSP3520_DISPLAY_MOSI_GPIO=10
# Pin 7:  SCK
CONFIG_MSP3520_DISPLAY_SCLK_GPIO=11
# Pin 8:  LED (backlight)
CONFIG_MSP3520_DISPLAY_BKL_GPIO=12
# Pin 9:  SDO (MISO)
CONFIG_MSP3520_DISPLAY_MISO_GPIO=13
CONFIG_MSP3520_DISPLAY_SPI_CLOCK_MHZ=40

# MSP3520 touch SPI (pins 10–14 on header)
# Pin 10: T_CLK
CONFIG_MSP3520_TOUCH_SCLK_GPIO=6
# Pin 11: T_CS
CONFIG_MSP3520_TOUCH_CS_GPIO=4
# Pin 12: T_DIN (MOSI)
CONFIG_MSP3520_TOUCH_MOSI_GPIO=7
# Pin 13: T_DO (MISO)
CONFIG_MSP3520_TOUCH_MISO_GPIO=8
# Pin 14: T_IRQ
CONFIG_MSP3520_TOUCH_IRQ_GPIO=5
CONFIG_MSP3520_TOUCH_SPI_CLOCK_KHZ=2000

# FreeRTOS — 1kHz tick for lower LVGL task latency
CONFIG_FREERTOS_HZ=1000

# Task watchdog — don't watch idle tasks (LVGL task may block)
CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU0=n
CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU1=n

# Logging — allow DEBUG level at compile time
CONFIG_LOG_MAXIMUM_LEVEL=4

# LVGL
CONFIG_LV_COLOR_DEPTH_24=y
CONFIG_LV_FONT_MONTSERRAT_24=y
CONFIG_LV_FONT_MONTSERRAT_28=y
CONFIG_LV_DEF_REFR_PERIOD=10
CONFIG_LV_BUILD_EXAMPLES=n
CONFIG_LV_BUILD_DEMOS=n
